---
const features = [
	{
		eyebrow: 'TENANT',
		title: 'Owner dashboard',
		body: 'Real-time check-ins, member roster, and quick actions. Every record is scoped to your gym_id — full isolation across every business on the platform.',
		points: ['Live check-in feed', 'Member & billing roster', 'Branding & hardware tokens'],
	},
	{
		eyebrow: 'INSPECT',
		title: 'Manager inspection view',
		body: 'Click any member to open a centralized timeline — payment standing, attendance history, and fitness graphs in one screen.',
		points: ['Payment standing', 'Attendance timeline', 'Body-metric graphs'],
	},
	{
		eyebrow: 'ENGAGE',
		title: 'Social member profile',
		body: 'An Instagram-grade profile: photo, bio, membership badge, and a progress tab for Squat / Bench / Deadlift PRs alongside weight and body-fat logs.',
		points: ['Profile + bio + badge', 'PR tracking', 'Weight / body-fat logs'],
	},
];
---

<section id="platform" class="border-b border-hairline bg-canvas-soft">
	<div class="mx-auto max-w-[1400px] px-4 py-24 sm:px-6">
		<div class="max-w-2xl">
			<p class="font-mono text-caption uppercase tracking-wide text-link">The platform</p>
			<h2 class="mt-3 text-display-lg text-ink">
				One database. Three portals.
			</h2>
			<p class="mt-4 text-body-lg text-body">
				A shared-database, isolated-tenant architecture that scales to any gym in the world —
				with a member experience that actually competes with consumer fitness apps.
			</p>
		</div>

		<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
			{
				features.map((f) => (
					<article class="flex flex-col rounded-md bg-canvas p-6 elev-3">
						<p class="font-mono text-caption uppercase tracking-wide text-mute">{f.eyebrow}</p>
						<h3 class="mt-2 text-display-sm text-ink">{f.title}</h3>
						<p class="mt-3 flex-1 text-body-md text-body">{f.body}</p>
						<ul class="mt-5 flex flex-col gap-2 border-t border-hairline pt-5">
							{f.points.map((p) => (
								<li class="flex items-center gap-2 text-body-sm text-body">
					    			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 text-link">
										<path d="M5 12.5l4 4 10-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
									{p}
								</li>
							))}
						</ul>
					</article>
				))
			}
		</div>
	</div>
</section>
