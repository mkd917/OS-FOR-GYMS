---
const stats = [
	{ value: '24/7', label: 'Unstaffed access' },
	{ value: '15s', label: 'QR rotation window' },
	{ value: '<50ms', label: 'Door-unlock verify' },
	{ value: '∞', label: 'Tenants per cluster' },
];
---

<section class="border-b border-hairline bg-canvas">
	<div class="mx-auto max-w-[1400px] px-4 py-10 sm:px-6">
		<p class="text-center font-mono text-caption uppercase tracking-wide text-mute">
			Built for independent studios, franchises, and 24/7 chains
		</p>
		<dl class="mt-8 grid grid-cols-2 gap-px overflow-hidden rounded-lg bg-hairline elev-1 md:grid-cols-4">
			{
				stats.map((s) => (
					<div class="flex flex-col items-center bg-canvas px-4 py-6 text-center">
						<dt class="text-display-md text-ink">{s.value}</dt>
						<dd class="mt-1 text-body-sm text-mute">{s.label}</dd>
					</div>
				))
			}
		</dl>
	</div>
</section>
