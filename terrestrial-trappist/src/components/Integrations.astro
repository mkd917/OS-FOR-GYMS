---
const integrations = [
	{ name: 'Apple HealthKit', detail: 'Native iOS hooks read background activity and push it to your member profile.' },
	{ name: 'Google Fit', detail: 'Daily health metrics sync through the Google REST API scopes you authorize.' },
	{ name: 'Webhooks & REST', detail: 'A clean, tenant-scoped API for billing events, check-ins, and member data.' },
];
---

<section id="docs" class="border-b border-hairline bg-canvas">
	<div class="mx-auto max-w-[1400px] px-4 py-24 sm:px-6">
		<div class="max-w-2xl">
			<p class="font-mono text-caption uppercase tracking-wide text-link">Integrations</p>
			<h2 class="mt-3 text-display-lg text-ink">Health data, synced for you.</h2>
			<p class="mt-4 text-body-lg text-body">
				Members shouldn't log every step by hand. Unified sync pipelines pull activity
				from the wearables they already wear.
			</p>
		</div>

		<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
			{
				integrations.map((i) => (
					<article class="rounded-md bg-canvas-soft p-6 elev-1">
						<div class="grid h-10 w-10 place-items-center rounded-md bg-canvas elev-1">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-ink">
								<path d="M12 21s-7-4.35-7-10a4 4 0 017-2.65A4 4 0 0119 11c0 5.65-7 10-7 10z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
							</svg>
						</div>
						<h3 class="mt-4 text-display-sm text-ink">{i.name}</h3>
						<p class="mt-2 text-body-md text-body">{i.detail}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
